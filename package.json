{
  "name": "contextbook",
  "version": "0.1.0",
  "description": "Turn your codebase and learning conversations into a personalized knowledge book.",
  "type": "module",
  "bin": {
    "contextbook": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "types": "./dist/core/index.d.ts",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "start": "node dist/cli.js",
    "test": "npm run build && node scripts/smoke-test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24.10.1"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "CHANGELOG.md"
  ],
  "license": "MIT"
}
